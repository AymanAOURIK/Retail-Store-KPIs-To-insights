# Copy to .env and fill in. .env is gitignored.

# OpenAI API key. The app degrades to a rule-based narrative if this is unset.
OPENAI_API_KEY=

# Model id. gpt-4o-mini is the default for cost; gpt-4o for the demo if needed.
OPENAI_MODEL=gpt-4o-mini

# LLM-as-judge model. Use a different one than the generator to avoid self-bias.
JUDGE_MODEL=gpt-4o

# Anonymisation toggle: when "true", store names are mapped to opaque aliases
# in every LLM payload. Default true.
ANONYMISE_STORES=true

# Where audit logs are written (gitignored).
AUDIT_LOG_PATH=audit_logs/llm_calls.jsonl
